#include <stdio.h>
#include <string.h>
#include <ctype.h>

int modInverse(int a, int m)
{
    int x;
    for (x = 1; x < m; x++)
    {
        if ((a * x) % m == 1)
            return x;
    }
    return -1;
}

int main()
{
    char cipher[1000];
    int a = 15;     // Obtained from frequency analysis
    int b = 19;
    int a_inv = modInverse(a, 26);

    printf("Enter Cipher Text (uppercase): ");
    scanf("%s", cipher);

    printf("Decrypted Text: ");

    for (int i = 0; cipher[i] != '\0'; i++)
    {
        if (isupper(cipher[i]))
        {
            int c = cipher[i] - 'A';
            int p = (a_inv * (c - b + 26)) % 26;
            printf("%c", p + 'A');
        }
        else
        {
            printf("%c", cipher[i]);
        }
    }

    printf("\n");

    return 0;
}
